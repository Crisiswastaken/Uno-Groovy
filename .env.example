# ---------------------------------------------------------------------------
# Custom UNO — environment variables
#
# Copy this file to `.env.local` for local development, or set these in your
# host's dashboard for a deployment. Every var here is NEXT_PUBLIC_* and is
# therefore inlined at BUILD time — rebuild/redeploy the web app after changing
# one.
# ---------------------------------------------------------------------------

# Host of the game server the browser connects to (no scheme). The name is kept
# for compatibility; it points at whatever hosts server/index.ts.
#   Local dev (when unset): 127.0.0.1:1999
#   Production: your deployed game server, e.g. custom-uno-server.onrender.com
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999

# App environment: "development" or "production".
# Leave UNSET to follow Next's NODE_ENV automatically (development under
# `next dev`, production under `next build` / `next start`). Set it explicitly
# only to override that default — e.g. "development" on a staging build to
# expose the dev-only /demo scratch routes (they 404 in production).
# NEXT_PUBLIC_APP_ENV=development
